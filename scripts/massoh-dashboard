#!/usr/bin/env python3
"""
massoh-dashboard — Massoh Fleet observability dashboard (slice 1a-0 skeleton).

Security model:
  N1  Bind hard-coded to 127.0.0.1 ONLY. Host is NOT configurable.
  N2  Route allowlist (NOT a static file server). Only GET / → 200 stub.
      Every other path → 404. No filesystem path resolution from URLs.
  N3  Clean lifecycle: foreground, blocking, SIGINT/SIGTERM → clean shutdown.
      Never auto-daemonized.
  N7  Python 3 stdlib ONLY — no pip, no PyYAML, no external deps.

Usage (called by lib/verbs/fleet.sh):
  scripts/massoh-dashboard [--port 8787]
"""

import argparse
import http.server
import signal
import socketserver
import sys
import threading

# N1: loopback-only — hard-coded; NOT derived from CLI args.
# This constant is the single source of truth for the bind address.
# The server NEVER binds to any other address (not configurable by design).
# The value is intentionally NOT 0.0.0.0 and NOT the empty string "".
BIND_HOST = "127.0.0.1"

DEFAULT_PORT = 8787

# N2: route allowlist — the ONLY allowed routes.
# Anything outside this set → 404. No path is ever turned into a filesystem path.
_ALLOWED_ROUTES = {
    "/": "text/html; charset=utf-8",
}

_STUB_HTML = """\
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Massoh Fleet</title>
  <!-- massoh-generated -->
</head>
<body>
  <h1>Massoh Fleet</h1>
  <p>Dashboard coming soon. (Slice 1a skeleton — prove bind + lifecycle first.)</p>
</body>
</html>
"""


class _FleetHandler(http.server.BaseHTTPRequestHandler):
    """
    N2: Custom handler with a fixed route allowlist.
    Does NOT extend SimpleHTTPRequestHandler; never calls translate_path().
    No byte of the caller-supplied path is ever os.path.join()-ed onto a
    filesystem root.  Anything not in _ALLOWED_ROUTES → 404.
    GET only in this skeleton (all other methods → 404).
    """

    def log_message(self, fmt, *args):  # noqa: D102 — suppress default access log to stderr
        pass

    def _send_404(self):
        body = b"404 Not Found\n"
        self.send_response(404)
        self.send_header("Content-Type", "text/plain; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def do_GET(self):  # noqa: N802 — name mandated by BaseHTTPRequestHandler
        # N2: strip query string / fragment before allowlist lookup.
        # We never parse the path into a filesystem location.
        path = self.path.split("?", 1)[0].split("#", 1)[0]

        if path not in _ALLOWED_ROUTES:
            # N2: anything not in the allowlist → 404 with zero reads.
            self._send_404()
            return

        content_type = _ALLOWED_ROUTES[path]
        if path == "/":
            body = _STUB_HTML.encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", content_type)
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
            return

        # Fallthrough (defensive): anything else not explicitly handled → 404.
        self._send_404()

    def do_HEAD(self):  # noqa: N802
        self._send_404()

    def do_POST(self):  # noqa: N802
        self._send_404()


def _make_server(port: int) -> socketserver.TCPServer:
    """
    N1: bind to BIND_HOST (127.0.0.1) ONLY.
    N3: allow_reuse_address=False (default) to fail fast if port is in use.
    """
    socketserver.TCPServer.allow_reuse_address = False
    server = socketserver.TCPServer((BIND_HOST, port), _FleetHandler)
    return server


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Massoh Fleet dashboard — 127.0.0.1 only, GET /, stdlib-only."
    )
    # N1: --port is the ONLY knob. Host is NOT configurable.
    parser.add_argument(
        "--port",
        type=int,
        default=DEFAULT_PORT,
        help=f"TCP port (default: {DEFAULT_PORT}). Host is always 127.0.0.1 (not configurable).",
    )
    args = parser.parse_args()

    port: int = args.port
    if port < 1 or port > 65535:
        print(f"massoh-dashboard: invalid port {port}", file=sys.stderr)
        return 1

    try:
        server = _make_server(port)
    except OSError as exc:
        print(f"massoh-dashboard: cannot bind {BIND_HOST}:{port}: {exc}", file=sys.stderr)
        return 1

    # N3: clean SIGINT/SIGTERM shutdown — no lingering process.
    # We run serve_forever() in a daemon thread so that the main thread can
    # block on a threading.Event and wake up on signal delivery.  This avoids
    # the deadlock that occurs when signal handlers call server.shutdown() from
    # inside the serve_forever() loop (which would wait on itself).
    _stop_event = threading.Event()

    def _shutdown(signum, frame):  # noqa: ARG001
        _stop_event.set()

    signal.signal(signal.SIGINT, _shutdown)
    signal.signal(signal.SIGTERM, _shutdown)

    # Start serve_forever() on a daemon thread.
    # Daemon=True means it won't block process exit if main() returns first.
    _server_thread = threading.Thread(target=server.serve_forever, daemon=True)
    _server_thread.start()

    # N3: print the URL before blocking.
    print(f"massoh-dashboard: serving at http://{BIND_HOST}:{port}/", flush=True)
    print("massoh-dashboard: press Ctrl-C or send SIGTERM to stop.", flush=True)

    # Block the main thread until a signal arrives.
    _stop_event.wait()

    # Signal received: request serve_forever() to exit, then close.
    server.shutdown()   # waits for serve_forever() thread to finish
    server.server_close()

    print("massoh-dashboard: stopped.", flush=True)
    return 0


if __name__ == "__main__":
    sys.exit(main())
