#!/usr/bin/env bash
# massoh — install/toggle/update the Massoh agent operating system.
# Global install lives in ~/.claude (override with CLAUDE_CONFIG_DIR). Everything Massoh writes is
# namespaced (massoh-*) and backed up before any change. See manifest.yml.
set -euo pipefail

# --- locate the Massoh repo (this script lives in <repo>/bin) ---
SELF="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
MASSOH_HOME="${MASSOH_HOME:-$SELF}"
CLAUDE_DIR="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
BLOCK_START="<!-- massoh:start"
BLOCK_END="<!-- massoh:end -->"
LINK=0   # default: copy (safe). --link to symlink into the clone (live updates).

say()  { printf '%s\n' "$*"; }
die()  { printf 'massoh: %s\n' "$*" >&2; exit 1; }
mver() { cat "$MASSOH_HOME/VERSION" 2>/dev/null || echo unknown; }
msha() { git -C "$MASSOH_HOME" rev-parse --short HEAD 2>/dev/null || echo '?'; }

backup_claude() {
  [ -d "$CLAUDE_DIR" ] || return 0
  local b="$CLAUDE_DIR/.massoh-backups/$(date +%Y%m%d-%H%M%S)"
  mkdir -p "$b"
  [ -f "$CLAUDE_DIR/CLAUDE.md" ] && cp -p "$CLAUDE_DIR/CLAUDE.md" "$b/CLAUDE.md" || true
  [ -d "$CLAUDE_DIR/agents" ]   && cp -rp "$CLAUDE_DIR/agents"  "$b/agents"  2>/dev/null || true
  [ -d "$CLAUDE_DIR/skills" ]   && cp -rp "$CLAUDE_DIR/skills"  "$b/skills"  2>/dev/null || true
  say "  backup → $b"
}

wire() {  # wire <src> <dest>  (copy, or symlink if --link)
  local src="$1" dest="$2"
  mkdir -p "$(dirname "$dest")"
  rm -rf "$dest"
  if [ "$LINK" = 1 ]; then ln -s "$src" "$dest"; else cp -rp "$src" "$dest"; fi
}

block_present() { [ -f "$CLAUDE_DIR/CLAUDE.md" ] && grep -qF "$BLOCK_START" "$CLAUDE_DIR/CLAUDE.md"; }

add_block() {
  mkdir -p "$CLAUDE_DIR"
  touch "$CLAUDE_DIR/CLAUDE.md"
  block_present && return 0
  printf '\n' >> "$CLAUDE_DIR/CLAUDE.md"
  cat "$MASSOH_HOME/templates/CLAUDE.global-block.md" >> "$CLAUDE_DIR/CLAUDE.md"
  say "  global block added → $CLAUDE_DIR/CLAUDE.md"
}

remove_block() {
  [ -f "$CLAUDE_DIR/CLAUDE.md" ] || return 0
  block_present || return 0
  awk -v s="$BLOCK_START" -v e="$BLOCK_END" '
    index($0,s){skip=1} !skip{print} index($0,e){skip=0}' \
    "$CLAUDE_DIR/CLAUDE.md" > "$CLAUDE_DIR/CLAUDE.md.tmp"
  mv "$CLAUDE_DIR/CLAUDE.md.tmp" "$CLAUDE_DIR/CLAUDE.md"
  say "  global block removed"
}

cmd_install() {
  say "massoh install → $CLAUDE_DIR  (mode: $([ "$LINK" = 1 ] && echo symlink || echo copy))"
  backup_claude
  mkdir -p "$CLAUDE_DIR/agents" "$CLAUDE_DIR/skills" "$CLAUDE_DIR/agent-os"
  # agents (namespaced massoh-*)
  for f in "$MASSOH_HOME"/claude/agents/massoh-*.md; do wire "$f" "$CLAUDE_DIR/agents/$(basename "$f")"; done
  # skills (owned names)
  for d in "$MASSOH_HOME"/claude/skills/*/; do wire "${d%/}" "$CLAUDE_DIR/skills/$(basename "$d")"; done
  # engine (read on demand)
  for p in OPERATING_SYSTEM.md policies templates docs manifest.yml VERSION; do
    [ -e "$MASSOH_HOME/$p" ] && wire "$MASSOH_HOME/$p" "$CLAUDE_DIR/agent-os/$p"; done
  add_block
  say "done. enabled globally; dormant until a repo opts in (massoh on)."
}

cmd_update() {
  say "massoh update"
  local stashed=0
  if [ -n "$(git -C "$MASSOH_HOME" status --porcelain 2>/dev/null)" ]; then
    say "  local changes present → stashing"
    git -C "$MASSOH_HOME" stash push -u -m "massoh-update-$(date +%s)" >/dev/null \
      || die "could not stash local changes; aborting (clone untouched)."
    stashed=1
  fi
  if ! git -C "$MASSOH_HOME" pull --ff-only; then
    [ "$stashed" = 1 ] && git -C "$MASSOH_HOME" stash pop >/dev/null 2>&1 || true
    die "pull not fast-forward; restored local state, aborting (nothing changed)."
  fi
  if [ "$stashed" = 1 ]; then
    git -C "$MASSOH_HOME" stash pop >/dev/null 2>&1 \
      || die "conflict restoring local edits — they are safe in 'git stash list'. Resolve, then 'massoh install'."
    say "  local changes restored"
  fi
  cmd_install
}

cmd_enable()  { say "massoh enable";  add_block;    say "done."; }
cmd_disable() { say "massoh disable"; backup_claude; remove_block; say "done. team dormant everywhere (files kept)."; }

# per-repo scaffold (create-if-missing; mirrors manifest.yml project_scaffold)
cmd_on() {
  local repo="${1:-$PWD}"; cd "$repo"
  say "massoh on → $repo"
  mkdir -p agent-project memory .agent_tasks
  scaffold CLAUDE.md                          templates/CLAUDE.project.template.md
  scaffold agent-project/CHARTER.md           templates/CHARTER.template.md
  scaffold agent-project/NON_NEGOTIABLES.md   templates/NON_NEGOTIABLES.template.md
  scaffold agent-project/PRODUCT_STRATEGY.md  templates/PRODUCT_STRATEGY.template.md
  scaffold agent-project/NOW_NEXT_LATER.md    templates/NOW_NEXT_LATER.template.md
  scaffold agent-project/METRICS.md           templates/METRICS.template.md
  scaffold AGENT_SYNC.md                      templates/AGENT_SYNC.skeleton.md
  scaffold AGENT_BACKLOG.md                   templates/AGENT_BACKLOG.skeleton.md
  scaffold memory/SCHEMA.md                   templates/MEMORY_SCHEMA.md
  [ -f memory/MEMORY.md ] || printf '# Memory index\n' > memory/MEMORY.md
  [ -f .agent_tasks/.gitkeep ] || : > .agent_tasks/.gitkeep
  printf 'massoh project marker — remove with `massoh off`\n' > .massoh
  say "done. fill in agent-project/*. This repo now engages the agent workflow."
}
scaffold() {  # scaffold <dest> <template>  (never overwrite)
  if [ -e "$1" ]; then say "  keep   $1 (exists)"; else cp "$MASSOH_HOME/$2" "$1"; say "  create $1"; fi
}

cmd_off() { rm -f "${1:-$PWD}/.massoh"; say "massoh off — repo dormant (files kept)."; }

cmd_version() { say "massoh $(mver) ($(msha))"; }

cmd_status() {
  say "Massoh status"
  say "  version: $(mver) ($(msha))"
  say "  repo:    $MASSOH_HOME ($(git -C "$MASSOH_HOME" rev-parse --short HEAD 2>/dev/null || echo '?'))"
  say "  global:  $([ -d "$CLAUDE_DIR/agent-os" ] && echo installed || echo 'not installed') @ $CLAUDE_DIR"
  say "  engaged: $(block_present && echo 'enabled (block present)' || echo 'disabled (no block)')"
  local n; n=$(ls "$CLAUDE_DIR"/agents/massoh-*.md 2>/dev/null | wc -l | tr -d ' ')
  say "  agents:  ${n} massoh-* installed"
  say "  here:    $([ -e "$PWD/.massoh" ] || [ -d "$PWD/agent-project" ] && echo 'ON (this repo is a Massoh project)' || echo 'off')"
}

# doctor — verify the live ~/.claude install matches what cmd_install writes. READ-ONLY (stdout only).
cmd_doctor() {
  say "massoh doctor → $CLAUDE_DIR"
  local problems=0 offline="${MASSOH_NO_FETCH:-0}"
  [ "${1:-}" = "--offline" ] && offline=1
  if block_present; then say "  ok   global block"; else say "  MISS global block (massoh enable)"; problems=$((problems+1)); fi
  for f in "$MASSOH_HOME"/claude/agents/massoh-*.md; do
    local a; a="$(basename "$f")"
    if [ -e "$CLAUDE_DIR/agents/$a" ]; then say "  ok   agent $a"; else say "  MISS agent $a"; problems=$((problems+1)); fi
  done
  for s in start-task sync close-task history-cleanup; do
    if [ -e "$CLAUDE_DIR/skills/$s" ]; then say "  ok   skill $s"; else say "  MISS skill $s"; problems=$((problems+1)); fi
  done
  for p in OPERATING_SYSTEM.md policies templates docs manifest.yml VERSION; do
    if [ -e "$CLAUDE_DIR/agent-os/$p" ]; then say "  ok   agent-os/$p"; else say "  MISS agent-os/$p"; problems=$((problems+1)); fi
  done
  say "  repo  $MASSOH_HOME  v$(mver) ($(msha))"
  # best-effort staleness check — informational only, NEVER changes exit code. opt-out: --offline / MASSOH_NO_FETCH=1
  if [ "$offline" != 1 ] && git -C "$MASSOH_HOME" rev-parse --git-dir >/dev/null 2>&1; then
    git -C "$MASSOH_HOME" fetch -q origin 2>/dev/null || true
    local head omain; head=$(git -C "$MASSOH_HOME" rev-parse HEAD 2>/dev/null || echo x)
    omain=$(git -C "$MASSOH_HOME" rev-parse origin/main 2>/dev/null || echo x)
    if [ "$head" != x ] && [ "$omain" != x ] && [ "$head" != "$omain" ] \
       && git -C "$MASSOH_HOME" merge-base --is-ancestor "$head" "$omain" 2>/dev/null; then
      say "  ⟳    update available → massoh update"
    fi
  fi
  if [ "$problems" -eq 0 ]; then say "healthy — install matches manifest."; else say "drift: $problems issue(s). fix: massoh install"; return 1; fi
}

# discover — mine the current repo's conventions into agent-project/STANDARDS.md (create-if-missing).
cmd_discover() {
  local repo="$PWD" force=0 a
  for a in "$@"; do [ "$a" = "--force" ] && force=1; done
  { [ -e "$repo/.massoh" ] || [ -d "$repo/agent-project" ]; } || die "not a Massoh project (run: massoh on)."
  mkdir -p "$repo/agent-project"
  local dest="$repo/agent-project/STANDARDS.md"
  if [ -e "$dest" ] && [ "$force" = 0 ]; then say "massoh discover — keep $dest (exists; --force to refresh)"; return 0; fi
  say "massoh discover → scanning $repo"
  local langs="" testcmd="" commitconv="" layout=""
  [ -f "$repo/package.json" ]   && langs="$langs JavaScript/TypeScript,"
  [ -f "$repo/go.mod" ]         && langs="$langs Go,"
  [ -f "$repo/Cargo.toml" ]     && langs="$langs Rust,"
  { [ -f "$repo/pyproject.toml" ] || [ -f "$repo/requirements.txt" ]; } && langs="$langs Python,"
  { [ -f "$repo/pom.xml" ] || [ -f "$repo/build.gradle" ]; }            && langs="$langs Java/JVM,"
  ls "$repo"/*.sh "$repo"/bin/* >/dev/null 2>&1 && langs="$langs Shell,"
  langs="${langs% }"; langs="${langs%,}"; [ -n "$langs" ] || langs="(none detected — fill in)"
  if [ -f "$repo/package.json" ] && grep -q '"test"' "$repo/package.json" 2>/dev/null; then testcmd="npm test"
  elif [ -f "$repo/Makefile" ] && grep -qiE '^test:' "$repo/Makefile" 2>/dev/null;     then testcmd="make test"
  elif [ -d "$repo/test" ] || [ -d "$repo/tests" ];                                     then testcmd="(test dir present — fill in runner)"
  else testcmd="(none detected — fill in)"; fi
  if git -C "$repo" rev-parse --git-dir >/dev/null 2>&1; then
    local conv; conv=$(git -C "$repo" log --pretty=%s -50 2>/dev/null | grep -cE '^(feat|fix|chore|docs|refactor|test|build|ci)(\(.+\))?(!)?:' || true)
    [ "${conv:-0}" -ge 5 ] && commitconv="Conventional Commits (seen in recent history)" || commitconv="(no clear convention — fill in)"
  else commitconv="(not a git repo)"; fi
  layout=$(ls -1 "$repo" 2>/dev/null | grep -vxE '\.git' | head -20 | sed 's/^/  - /')
  sed -e "s|{{LANGS}}|$langs|g" -e "s|{{TESTCMD}}|$testcmd|g" \
      -e "s|{{COMMITCONV}}|$commitconv|g" -e "s|{{DATE}}|$(date +%Y-%m-%d)|g" \
      "$MASSOH_HOME/templates/STANDARDS.template.md" \
    | awk -v L="$layout" '/\{\{LAYOUT\}\}/{print L; next} {print}' > "$dest"
  say "  wrote $dest — review + fill the (…) placeholders."
}

# review — the KPI "review ceremony": gather metrics (read-only) + append a METRICS snapshot.
cmd_review() {
  local since=7 write=1 runtests=0
  while [ $# -gt 0 ]; do case "$1" in
    --since) shift; since="${1:-7}";; --no-write) write=0;; --run-tests) runtests=1;;
    *) die "unknown review flag: $1";; esac; shift; done
  local repo; repo="$(git -C "$PWD" rev-parse --show-toplevel 2>/dev/null || pwd)"
  local ts; ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  local pt=0 prev=0 plic=0 d
  if [ -d "$repo/.agent_tasks" ]; then
    for d in "$repo"/.agent_tasks/TASK-*/; do [ -d "$d" ] || continue; pt=$((pt+1))
      [ -f "${d}06_review_result.md" ] && prev=$((prev+1))
      [ -f "${d}04_implementation_packet.md" ] && plic=$((plic+1)); done
  fi
  local popen=$((pt - prev))
  local bl="$repo/AGENT_BACKLOG.md" td=0 dg=0 dn=0 bk=0
  if [ -f "$bl" ]; then
    td=$(grep -c '| TODO |' "$bl" || true); dg=$(grep -c '| DOING |' "$bl" || true)
    dn=$(grep -c '| DONE |' "$bl" || true); bk=$(grep -c '| BLOCKED |' "$bl" || true)
  fi
  local prs=0 commits=0 reverts=0 featb=0 cronb=0
  if git -C "$repo" rev-parse --git-dir >/dev/null 2>&1; then
    prs=$(git -C "$repo" log --oneline 2>/dev/null | grep -cE '\(#[0-9]+\)' || true)
    commits=$(git -C "$repo" log --oneline --since="$since days ago" 2>/dev/null | wc -l | tr -d ' ')
    reverts=$(git -C "$repo" log --oneline 2>/dev/null | grep -ci revert || true)
    featb=$(git -C "$repo" branch --list 'feat/*' 2>/dev/null | grep -c . || true)
    cronb=$(git -C "$repo" branch --list 'cron/*' 2>/dev/null | grep -c . || true)
  fi
  local testline="skipped (--run-tests to run)"
  [ "$runtests" = 1 ] && [ -f "$repo/test/run.sh" ] && testline="$(cd "$repo" && bash test/run.sh 2>&1 | tail -1)"
  local report="massoh review — $ts  (v$(mver))
  packets:   $pt total · $prev reviewed · $plic licensed · $popen open
  backlog:   $td TODO · $dg DOING · $dn DONE · $bk BLOCKED
  delivery:  $prs PRs merged · $commits commits/${since}d · $reverts reverts
  branches:  $featb feat/* · $cronb cron/*
  quality:   $testline"
  say "$report"
  if [ "$write" = 1 ]; then
    mkdir -p "$repo/agent-project"
    { printf '\n## Snapshot %s (v%s)\n' "$ts" "$(mver)"; printf '%s\n' "$report" | sed '1d; s/^  /- /'; } >> "$repo/agent-project/METRICS.md"
    say "  → appended snapshot to agent-project/METRICS.md"
  fi
}

# standup — the progress-delta "ceremony": what moved since last tick (read-only + optional sync append).
cmd_standup() {
  local since=1 write=1
  while [ $# -gt 0 ]; do case "$1" in --since) shift; since="${1:-1}";; --no-write) write=0;; *) die "unknown standup flag: $1";; esac; shift; done
  local repo; repo="$(git -C "$PWD" rev-parse --show-toplevel 2>/dev/null || pwd)"
  local ts; ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  local commits="(none)" doing="(none)" blocked="(none)" inflight="(none)" d
  if git -C "$repo" rev-parse --git-dir >/dev/null 2>&1; then
    commits="$(git -C "$repo" log --since="$since days ago" --pretty='%h %s' 2>/dev/null | sed 's/^/    - /')"; [ -z "$commits" ] && commits="    (none)"
  fi
  local bl="$repo/AGENT_BACKLOG.md"
  if [ -f "$bl" ]; then
    doing="$(grep -E '\| DOING \|' "$bl" | sed -E 's/^/    -/; s/\|/ /g' || true)"; [ -z "$doing" ] && doing="    (none)"
    blocked="$(grep -E '\| BLOCKED \|' "$bl" | sed -E 's/^/    -/; s/\|/ /g' || true)"; [ -z "$blocked" ] && blocked="    (none)"
  fi
  if [ -d "$repo/.agent_tasks" ]; then
    inflight=""; for d in "$repo"/.agent_tasks/TASK-*/; do [ -d "$d" ] || continue
      [ -f "${d}04_implementation_packet.md" ] && [ ! -f "${d}06_review_result.md" ] && inflight="$inflight    - $(basename "$d")"$'\n'; done
    [ -z "$inflight" ] && inflight="    (none)" || inflight="${inflight%$'\n'}"
  fi
  local report="massoh standup — $ts  (since ${since}d)
  commits:
$commits
  DOING:
$doing
  BLOCKED:
$blocked
  in-flight packets (licensed, unreviewed):
$inflight"
  say "$report"
  if [ "$write" = 1 ] && [ -f "$repo/AGENT_SYNC.md" ]; then
    { printf '\n## [standup] %s\n' "$ts"; printf '%s\n' "$report" | sed '1d; s/^  /- /; s/^    /  /'; } >> "$repo/AGENT_SYNC.md"
    say "  → appended to AGENT_SYNC.md"
  fi
}

# plan — the planning "ceremony": prioritized queue + surface owner decisions (read-only + optional append).
cmd_plan() {
  local write=1
  while [ $# -gt 0 ]; do case "$1" in --no-write) write=0;; *) die "unknown plan flag: $1";; esac; shift; done
  local repo; repo="$(git -C "$PWD" rev-parse --show-toplevel 2>/dev/null || pwd)"
  local ts; ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  local queue="(none)" decisions="(none)" blocked="(none)"
  local bl="$repo/AGENT_BACKLOG.md"
  if [ -f "$bl" ]; then
    queue="$(awk -F'|' '/^\|/{st=$6;gsub(/^[ \t]+|[ \t]+$/,"",st); if(st=="TODO"){pr=$3;it=$4;gsub(/^[ \t]+|[ \t]+$/,"",pr);gsub(/^[ \t]+|[ \t]+$/,"",it);print "    - ["pr"] "it}}' "$bl")"; [ -z "$queue" ] && queue="    (none)"
    blocked="$(grep -E '\| BLOCKED \|' "$bl" | sed -E 's/^/    -/; s/\|/ /g' || true)"; [ -z "$blocked" ] && blocked="    (none)"
  fi
  local sy="$repo/AGENT_SYNC.md"
  if [ -f "$sy" ]; then
    decisions="$(awk '/^## Open questions/{f=1;next} /^## /{f=0} f && /^\| / && $0 !~ /Question|^\|-|---/ {print "    -"$0}' "$sy" | sed 's/|/ /g')"; [ -z "$decisions" ] && decisions="    (none open)"
  fi
  local report="massoh plan — $ts
  queue (top = next):
$queue
  owner decisions needed:
$decisions
  BLOCKED:
$blocked"
  say "$report"
  if [ "$write" = 1 ] && [ -f "$sy" ]; then
    { printf '\n## [plan] %s\n' "$ts"; printf '%s\n' "$report" | sed '1d; s/^  /- /; s/^    /  /'; } >> "$sy"
    say "  → appended to AGENT_SYNC.md"
  fi
}

# learn — heuristic read-only miner: review history, decision log, git reverts → lessons report.
# NO LLM / NO claude -p / zero spend. Proposals (--write-proposals) go ONLY to LEARNINGS.proposed.md.
cmd_learn() {
  local since=0 write_proposals=0
  while [ $# -gt 0 ]; do case "$1" in
    --since)           shift; since="${1:-0}";;
    --write-proposals) write_proposals=1;;
    --no-write)        write_proposals=0;;
    *) die "unknown learn flag: $1";;
  esac; shift; done

  local repo; repo="$(git -C "$PWD" rev-parse --show-toplevel 2>/dev/null || pwd)"

  # Non-Massoh-project guard (same pattern as cmd_discover)
  { [ -e "$repo/.massoh" ] || [ -d "$repo/agent-project" ]; } \
    || die "not a Massoh project (run: massoh on)."

  local ts; ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

  # task-packet-spec: these heading/keyword names match mandatory sections in 11_TASK_PACKET_SPEC.md
  # and the AGENT_SYNC schema. Extracted as named variables for future multi-language projects.
  local _PAT_BLOCKING='## Blocking'
  local _PAT_NONBLOCKING='## Non-blocking'
  local _PAT_REQUEST_CHANGES='REQUEST CHANGES'
  local _PAT_DECISION_LOG='## Decision log'
  local _PAT_ADR_FLAG='irreversible'

  # --- 1. Scan 06_review_result.md + 05_implementation_handoff.md ---
  local blocking_lines="" nonblocking_lines="" risks_lines="" packet_count=0

  if [ -d "$repo/.agent_tasks" ]; then
    local d
    for d in "$repo"/.agent_tasks/TASK-*/; do
      [ -d "$d" ] || continue
      local f06="${d}06_review_result.md"
      local f05="${d}05_implementation_handoff.md"

      # Apply --since filter via mtime (0 means no filter)
      if [ "$since" -gt 0 ]; then
        local recent06=0 recent05=0
        [ -f "$f06" ] && recent06=$(find "$f06" -mtime -"${since}" 2>/dev/null | grep -c . || true)
        [ -f "$f05" ] && recent05=$(find "$f05" -mtime -"${since}" 2>/dev/null | grep -c . || true)
        [ "$recent06" -eq 0 ] && [ "$recent05" -eq 0 ] && continue
      fi

      packet_count=$((packet_count + 1))

      # Mine blocking section from 06
      if [ -f "$f06" ]; then
        local b; b=$(awk -v hdr="$_PAT_BLOCKING" '
          /^## /{if($0~hdr){in_s=1;next}else{in_s=0}}
          in_s && /\S/{print}
        ' "$f06" || true)
        [ -n "$b" ] && blocking_lines="$blocking_lines"$'\n'"$(basename "$d"): $b"

        # Mine non-blocking section from 06
        local nb; nb=$(awk -v hdr="$_PAT_NONBLOCKING" '
          /^## /{if($0~hdr){in_s=1;next}else{in_s=0}}
          in_s && /\S/{print}
        ' "$f06" || true)
        [ -n "$nb" ] && nonblocking_lines="$nonblocking_lines"$'\n'"$(basename "$d"): $nb"

        # Mine REQUEST CHANGES lines (use grep -F for literal match; guarded with || true)
        local rc; rc=$(grep -F "$_PAT_REQUEST_CHANGES" "$f06" || true)
        [ -n "$rc" ] && blocking_lines="$blocking_lines"$'\n'"$(basename "$d"): $rc"
      fi

      # Mine risks from 05
      if [ -f "$f05" ]; then
        local rk; rk=$(grep -iE '^[-*].*[Rr]isk|^##.*[Rr]isk|[Rr]isk:' "$f05" || true)
        [ -n "$rk" ] && risks_lines="$risks_lines"$'\n'"$(basename "$d"): $rk"
      fi
    done
  fi

  # --- 2. Count recurring patterns (keyword seen in 2+ review files) ---
  local recurring_summary="    (none)"
  if [ -n "$blocking_lines" ] && [ -d "$repo/.agent_tasks" ]; then
    local kw_counts; kw_counts=""
    local f06
    for f06 in "$repo"/.agent_tasks/TASK-*/06_review_result.md; do
      [ -f "$f06" ] || continue
      if [ "$since" -gt 0 ]; then
        local recent; recent=$(find "$f06" -mtime -"${since}" 2>/dev/null | grep -c . || true)
        [ "$recent" -eq 0 ] && continue
      fi
      # Extract words (5+ chars) from blocking sections + REQUEST CHANGES lines
      local words; words=$(awk -v hdr="$_PAT_BLOCKING" -v rch="$_PAT_REQUEST_CHANGES" '
        /^## /{if($0~hdr){in_s=1;next}else{in_s=0}}
        in_s && /\S/{print}
        index($0,rch){print}
      ' "$f06" | grep -oE '[A-Za-z_|&]{5,}' || true)
      kw_counts="$kw_counts $words"
    done
    # Count each keyword; surface those seen in 2+ reviews
    local recurring; recurring=$(printf '%s\n' $kw_counts | sort | uniq -c | sort -rn | \
      awk '$1>=2{printf "    - (x%d) %s\n",$1,$2}' || true)
    if [ -n "$recurring" ]; then
      recurring_summary="$recurring"
    else
      recurring_summary="    (none — no pattern seen in 2+ reviews)"
    fi
  fi

  [ -z "$blocking_lines" ]    && blocking_lines="    (none)"
  [ -z "$nonblocking_lines" ] && nonblocking_lines="    (none)"
  [ -z "$risks_lines" ]       && risks_lines="    (none)"

  # --- 3. Decision log ADR candidates ---
  local adr_candidates="    (none)"
  local sy="$repo/AGENT_SYNC.md"
  if [ -f "$sy" ]; then
    # Use grep + awk: grep for irreversible lines in the decision log section
    # Pass variable values via awk -v to avoid literal interpolation pitfalls
    local adr; adr=$(awk -v hdr="$_PAT_DECISION_LOG" -v flag="$_PAT_ADR_FLAG" '
      /^## /{if(index($0,hdr)){in_s=1;next}else{in_s=0}}
      in_s && /\|/ && tolower($0)~flag{print "    -"$0}
    ' "$sy" || true)
    [ -n "$adr" ] && adr_candidates="$adr"
  fi

  # --- 4. Git revert + fixup counts ---
  local revert_count=0 fixup_count=0
  if git -C "$repo" rev-parse --git-dir >/dev/null 2>&1; then
    local gitlog_args="--oneline"
    [ "$since" -gt 0 ] && gitlog_args="$gitlog_args --since=${since} days ago"
    # shellcheck disable=SC2086
    revert_count=$(git -C "$repo" log $gitlog_args 2>/dev/null | grep -ci revert || true)
    # shellcheck disable=SC2086
    fixup_count=$(git -C "$repo" log $gitlog_args 2>/dev/null | grep -ci fixup || true)
  fi

  # --- 5. Build and print the lessons report ---
  local ver; ver="$(mver)"
  say "massoh learn — $ts  (v$ver)  [scanned $packet_count packet(s)]"
  say "  Blocking findings (from 06_review_result.md):"
  say "$blocking_lines"
  say "  Non-blocking findings:"
  say "$nonblocking_lines"
  say "  Recurring review findings (seen in 2+ reviews):"
  say "$recurring_summary"
  say "  Risks seen (from 05_implementation_handoff.md):"
  say "$risks_lines"
  say "  ADR candidates (decision log rows flagged '$_PAT_ADR_FLAG'):"
  say "$adr_candidates"
  say "  Repeated-fix indicators (git):"
  say "    - revert commit(s): $revert_count"
  say "    - fixup commit(s):  $fixup_count"

  # --- 6. Optionally append proposals ---
  if [ "$write_proposals" = 1 ]; then
    local proposals="$repo/agent-project/LEARNINGS.proposed.md"
    mkdir -p "$repo/agent-project"
    {
      printf '\n## [learn] %s (v%s)\n' "$ts" "$ver"
      printf '### Proposed STANDARDS.md Do/Don'"'"'t\n'
      if [ "$blocking_lines" != "    (none)" ]; then
        printf '%s\n' "$blocking_lines" | sed 's/^[[:space:]]*/- /'
      else
        printf -- '- (none)\n'
      fi
      printf '### Possible ADR candidates (from decision log)\n'
      if [ "$adr_candidates" != "    (none)" ]; then
        printf '%s\n' "$adr_candidates"
      else
        printf -- '- (none)\n'
      fi
      printf '### Repeated-fix indicators (git)\n'
      printf -- '- %d revert commit(s) found — review for recurring root causes\n' "$revert_count"
      printf -- '- %d fixup commit(s) found\n' "$fixup_count"
    } >> "$proposals" # SAFETY: only permitted write in cmd_learn
    say "  → appended proposals to $proposals"
  fi
}

# cron — the autonomous loop runner (separate script; safe-by-default: dry-run, no auto-merge).
cmd_cron() { exec "$MASSOH_HOME/bin/massoh-cron" "$@"; }

cmd_work() { local r="${1:?usage: massoh work <repo>}"; cd "$r"; exec "${MASSOH_CLAUDE:-claude}"; }

cmd_uninstall() {
  say "massoh uninstall"
  backup_claude
  rm -f "$CLAUDE_DIR"/agents/massoh-*.md
  for s in start-task sync close-task history-cleanup; do rm -rf "$CLAUDE_DIR/skills/$s"; done
  rm -rf "$CLAUDE_DIR/agent-os"
  remove_block
  say "done. removed global footprint (backup kept; per-repo agent-project/ left untouched)."
}

# --- args ---
for a in "$@"; do [ "$a" = "--link" ] && LINK=1; done
cmd="${1:-status}"; [ "$cmd" = "--link" ] && cmd="${2:-status}"
case "$cmd" in
  install)   cmd_install ;;
  update)    cmd_update ;;
  on|init)   shift || true; cmd_on "${1:-$PWD}" ;;
  off)       shift || true; cmd_off "${1:-$PWD}" ;;
  enable)    cmd_enable ;;
  disable)   cmd_disable ;;
  status)    cmd_status ;;
  doctor)    shift || true; cmd_doctor "$@" ;;
  discover)  shift || true; cmd_discover "$@" ;;
  review)    shift || true; cmd_review "$@" ;;
  standup)   shift || true; cmd_standup "$@" ;;
  plan)      shift || true; cmd_plan "$@" ;;
  learn)     shift || true; cmd_learn "$@" ;;
  cron)      shift || true; cmd_cron "$@" ;;
  version|--version|-v) cmd_version ;;
  work)      shift; cmd_work "${1:-}" ;;
  uninstall) cmd_uninstall ;;
  *) die "unknown command '$cmd'. verbs: install update on off enable disable status doctor discover review standup plan learn cron version work uninstall [--link]" ;;
esac
