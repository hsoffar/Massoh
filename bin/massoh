#!/usr/bin/env bash
# massoh — install/toggle/update the Massoh agent operating system.
# Global install lives in ~/.claude (override with CLAUDE_CONFIG_DIR). Everything Massoh writes is
# namespaced (massoh-*) and backed up before any change. See manifest.yml.
set -euo pipefail

# --- locate the Massoh repo (this script lives in <repo>/bin) ---
SELF="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
MASSOH_HOME="${MASSOH_HOME:-$SELF}"
CLAUDE_DIR="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
BLOCK_START="<!-- massoh:start"
BLOCK_END="<!-- massoh:end -->"
LINK=0   # default: copy (safe). --link to symlink into the clone (live updates).

say()  { printf '%s\n' "$*"; }
die()  { printf 'massoh: %s\n' "$*" >&2; exit 1; }
mver() { cat "$MASSOH_HOME/VERSION" 2>/dev/null || echo unknown; }
msha() { git -C "$MASSOH_HOME" rev-parse --short HEAD 2>/dev/null || echo '?'; }

backup_claude() {
  [ -d "$CLAUDE_DIR" ] || return 0
  local b="$CLAUDE_DIR/.massoh-backups/$(date +%Y%m%d-%H%M%S)"
  mkdir -p "$b"
  [ -f "$CLAUDE_DIR/CLAUDE.md" ] && cp -p "$CLAUDE_DIR/CLAUDE.md" "$b/CLAUDE.md" || true
  [ -d "$CLAUDE_DIR/agents" ]   && cp -rp "$CLAUDE_DIR/agents"  "$b/agents"  2>/dev/null || true
  [ -d "$CLAUDE_DIR/skills" ]   && cp -rp "$CLAUDE_DIR/skills"  "$b/skills"  2>/dev/null || true
  say "  backup → $b"
}

wire() {  # wire <src> <dest>  (copy, or symlink if --link)
  local src="$1" dest="$2"
  mkdir -p "$(dirname "$dest")"
  rm -rf "$dest"
  if [ "$LINK" = 1 ]; then ln -s "$src" "$dest"; else cp -rp "$src" "$dest"; fi
}

block_present() { [ -f "$CLAUDE_DIR/CLAUDE.md" ] && grep -qF "$BLOCK_START" "$CLAUDE_DIR/CLAUDE.md"; }

add_block() {
  mkdir -p "$CLAUDE_DIR"
  touch "$CLAUDE_DIR/CLAUDE.md"
  block_present && return 0
  printf '\n' >> "$CLAUDE_DIR/CLAUDE.md"
  cat "$MASSOH_HOME/templates/CLAUDE.global-block.md" >> "$CLAUDE_DIR/CLAUDE.md"
  say "  global block added → $CLAUDE_DIR/CLAUDE.md"
}

remove_block() {
  [ -f "$CLAUDE_DIR/CLAUDE.md" ] || return 0
  block_present || return 0
  awk -v s="$BLOCK_START" -v e="$BLOCK_END" '
    index($0,s){skip=1} !skip{print} index($0,e){skip=0}' \
    "$CLAUDE_DIR/CLAUDE.md" > "$CLAUDE_DIR/CLAUDE.md.tmp"
  mv "$CLAUDE_DIR/CLAUDE.md.tmp" "$CLAUDE_DIR/CLAUDE.md"
  say "  global block removed"
}

cmd_install() {
  say "massoh install → $CLAUDE_DIR  (mode: $([ "$LINK" = 1 ] && echo symlink || echo copy))"
  backup_claude
  mkdir -p "$CLAUDE_DIR/agents" "$CLAUDE_DIR/skills" "$CLAUDE_DIR/agent-os"
  # agents (namespaced massoh-*)
  for f in "$MASSOH_HOME"/claude/agents/massoh-*.md; do wire "$f" "$CLAUDE_DIR/agents/$(basename "$f")"; done
  # skills (owned names)
  for d in "$MASSOH_HOME"/claude/skills/*/; do wire "${d%/}" "$CLAUDE_DIR/skills/$(basename "$d")"; done
  # engine (read on demand)
  for p in OPERATING_SYSTEM.md policies templates docs manifest.yml VERSION lib/verbs; do
    [ -e "$MASSOH_HOME/$p" ] && wire "$MASSOH_HOME/$p" "$CLAUDE_DIR/agent-os/$p"; done
  add_block
  say "done. enabled globally; dormant until a repo opts in (massoh on)."
}

cmd_update() {
  say "massoh update"
  local stashed=0
  if [ -n "$(git -C "$MASSOH_HOME" status --porcelain 2>/dev/null)" ]; then
    say "  local changes present → stashing"
    git -C "$MASSOH_HOME" stash push -u -m "massoh-update-$(date +%s)" >/dev/null \
      || die "could not stash local changes; aborting (clone untouched)."
    stashed=1
  fi
  if ! git -C "$MASSOH_HOME" pull --ff-only; then
    [ "$stashed" = 1 ] && git -C "$MASSOH_HOME" stash pop >/dev/null 2>&1 || true
    die "pull not fast-forward; restored local state, aborting (nothing changed)."
  fi
  if [ "$stashed" = 1 ]; then
    git -C "$MASSOH_HOME" stash pop >/dev/null 2>&1 \
      || die "conflict restoring local edits — they are safe in 'git stash list'. Resolve, then 'massoh install'."
    say "  local changes restored"
  fi
  cmd_install
}

cmd_enable()  { say "massoh enable";  add_block;    say "done."; }
cmd_disable() { say "massoh disable"; backup_claude; remove_block; say "done. team dormant everywhere (files kept)."; }

# per-repo scaffold (create-if-missing; mirrors manifest.yml project_scaffold)
cmd_on() {
  local repo="${1:-$PWD}"; cd "$repo"
  say "massoh on → $repo"
  mkdir -p agent-project memory .agent_tasks
  scaffold CLAUDE.md                          templates/CLAUDE.project.template.md
  scaffold agent-project/CHARTER.md           templates/CHARTER.template.md
  scaffold agent-project/NON_NEGOTIABLES.md   templates/NON_NEGOTIABLES.template.md
  scaffold agent-project/PRODUCT_STRATEGY.md  templates/PRODUCT_STRATEGY.template.md
  scaffold agent-project/NOW_NEXT_LATER.md    templates/NOW_NEXT_LATER.template.md
  scaffold agent-project/METRICS.md           templates/METRICS.template.md
  scaffold AGENT_SYNC.md                      templates/AGENT_SYNC.skeleton.md
  scaffold AGENT_BACKLOG.md                   templates/AGENT_BACKLOG.skeleton.md
  scaffold memory/SCHEMA.md                   templates/MEMORY_SCHEMA.md
  [ -f memory/MEMORY.md ] || printf '# Memory index\n' > memory/MEMORY.md
  [ -f .agent_tasks/.gitkeep ] || : > .agent_tasks/.gitkeep
  printf 'massoh project marker — remove with `massoh off`\n' > .massoh
  say "done. fill in agent-project/*. This repo now engages the agent workflow."
}
scaffold() {  # scaffold <dest> <template>  (never overwrite)
  if [ -e "$1" ]; then say "  keep   $1 (exists)"; else cp "$MASSOH_HOME/$2" "$1"; say "  create $1"; fi
}

cmd_off() { rm -f "${1:-$PWD}/.massoh"; say "massoh off — repo dormant (files kept)."; }

cmd_version() { say "massoh $(mver) ($(msha))"; }

cmd_status() {
  say "Massoh status"
  say "  version: $(mver) ($(msha))"
  say "  repo:    $MASSOH_HOME ($(git -C "$MASSOH_HOME" rev-parse --short HEAD 2>/dev/null || echo '?'))"
  say "  global:  $([ -d "$CLAUDE_DIR/agent-os" ] && echo installed || echo 'not installed') @ $CLAUDE_DIR"
  say "  engaged: $(block_present && echo 'enabled (block present)' || echo 'disabled (no block)')"
  local n; n=$(ls "$CLAUDE_DIR"/agents/massoh-*.md 2>/dev/null | wc -l | tr -d ' ')
  say "  agents:  ${n} massoh-* installed"
  say "  here:    $([ -e "$PWD/.massoh" ] || [ -d "$PWD/agent-project" ] && echo 'ON (this repo is a Massoh project)' || echo 'off')"
}

# doctor — verify the live ~/.claude install matches what cmd_install writes. READ-ONLY (stdout only).
cmd_doctor() {
  say "massoh doctor → $CLAUDE_DIR"
  local problems=0 offline="${MASSOH_NO_FETCH:-0}"
  [ "${1:-}" = "--offline" ] && offline=1
  if block_present; then say "  ok   global block"; else say "  MISS global block (massoh enable)"; problems=$((problems+1)); fi
  for f in "$MASSOH_HOME"/claude/agents/massoh-*.md; do
    local a; a="$(basename "$f")"
    if [ -e "$CLAUDE_DIR/agents/$a" ]; then say "  ok   agent $a"; else say "  MISS agent $a"; problems=$((problems+1)); fi
  done
  for s in start-task sync close-task history-cleanup; do
    if [ -e "$CLAUDE_DIR/skills/$s" ]; then say "  ok   skill $s"; else say "  MISS skill $s"; problems=$((problems+1)); fi
  done
  for p in OPERATING_SYSTEM.md policies templates docs manifest.yml VERSION; do
    if [ -e "$CLAUDE_DIR/agent-os/$p" ]; then say "  ok   agent-os/$p"; else say "  MISS agent-os/$p"; problems=$((problems+1)); fi
  done
  # MB4: verify lib/verbs/ presence (added in v0.11.0)
  if [ -d "$CLAUDE_DIR/agent-os/lib/verbs" ]; then say "  ok   agent-os/lib/verbs/"; else say "  MISS agent-os/lib/verbs/"; problems=$((problems+1)); fi
  say "  repo  $MASSOH_HOME  v$(mver) ($(msha))"
  # best-effort staleness check — informational only, NEVER changes exit code. opt-out: --offline / MASSOH_NO_FETCH=1
  if [ "$offline" != 1 ] && git -C "$MASSOH_HOME" rev-parse --git-dir >/dev/null 2>&1; then
    git -C "$MASSOH_HOME" fetch -q origin 2>/dev/null || true
    local head omain; head=$(git -C "$MASSOH_HOME" rev-parse HEAD 2>/dev/null || echo x)
    omain=$(git -C "$MASSOH_HOME" rev-parse origin/main 2>/dev/null || echo x)
    if [ "$head" != x ] && [ "$omain" != x ] && [ "$head" != "$omain" ] \
       && git -C "$MASSOH_HOME" merge-base --is-ancestor "$head" "$omain" 2>/dev/null; then
      say "  ⟳    update available → massoh update"
    fi
  fi
  if [ "$problems" -eq 0 ]; then say "healthy — install matches manifest."; else say "drift: $problems issue(s). fix: massoh install"; return 1; fi
}

# --- gate globals (must be defined before lib/verbs/gate.sh is sourced) ---
GATE_MARKER_START="# massoh-gate:start"
GATE_MARKER_END="# massoh-gate:end"

# --- source verb files from lib/verbs/ (MB1: derived from $MASSOH_HOME, symlink-safe) ---
for _verb_file in "$MASSOH_HOME/lib/verbs/"*.sh; do
  [ -f "$_verb_file" ] || { printf 'massoh: missing lib file: %s\n' "$_verb_file" >&2; exit 1; }
  # shellcheck source=/dev/null
  . "$_verb_file"
done
unset _verb_file

cmd_uninstall() {
  say "massoh uninstall"
  backup_claude
  rm -f "$CLAUDE_DIR"/agents/massoh-*.md
  for s in start-task sync close-task history-cleanup; do rm -rf "$CLAUDE_DIR/skills/$s"; done
  rm -rf "$CLAUDE_DIR/agent-os"
  remove_block
  say "done. removed global footprint (backup kept; per-repo agent-project/ left untouched)."
}

# --- args ---
for a in "$@"; do [ "$a" = "--link" ] && LINK=1; done
cmd="${1:-status}"; [ "$cmd" = "--link" ] && cmd="${2:-status}"
case "$cmd" in
  install)   cmd_install ;;
  update)    cmd_update ;;
  on|init)   shift || true; cmd_on "${1:-$PWD}" ;;
  off)       shift || true; cmd_off "${1:-$PWD}" ;;
  enable)    cmd_enable ;;
  disable)   cmd_disable ;;
  status)    cmd_status ;;
  doctor)    shift || true; cmd_doctor "$@" ;;
  discover)  shift || true; cmd_discover "$@" ;;
  review)    shift || true; cmd_review "$@" ;;
  standup)   shift || true; cmd_standup "$@" ;;
  plan)      shift || true; cmd_plan "$@" ;;
  learn)     shift || true; cmd_learn "$@" ;;
  recommend) shift || true; cmd_recommend "$@" ;;
  ledger)    shift || true; cmd_ledger "$@" ;;
  meta)      shift || true; cmd_meta "$@" ;;
  cron)      shift || true; cmd_cron "$@" ;;
  gate)      shift || true; cmd_gate "$@" ;;
  board)     shift || true; cmd_board "$@" ;;
  intake)    shift || true; cmd_intake "$@" ;;
  version|--version|-v) cmd_version ;;
  work)      shift; cmd_work "${1:-}" ;;
  uninstall) cmd_uninstall ;;
  *) die "unknown command '$cmd'. verbs: install update on off enable disable status doctor discover review standup plan learn recommend ledger meta cron gate board intake version work uninstall [--link]" ;;
esac
